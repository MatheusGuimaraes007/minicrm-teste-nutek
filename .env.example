# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=minicrm_db

# ── Auth Service ─────────────────────────────────────────
# Chave secreta para assinar tokens JWT (access token, 15min)
JWT_SECRET=dev_jwt_secret_minicrm_2026_super_secreto
# Chave secreta para assinar refresh tokens (7 dias)
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_minicrm_2026_mega_secreto

# ── n8n ──────────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123

# ── Cloudflare (para CI/CD — diferencial) ────────────────
# CF_API_TOKEN=your_cloudflare_api_token
# CF_ACCOUNT_ID=your_cloudflare_account_id
